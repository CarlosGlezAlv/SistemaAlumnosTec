<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/docentes_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_bg">

    <!-- AppBar con toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_docentes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_docentes"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/tec_red"
            app:title="@string/docentes_title"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido con scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ─── CARD: DATOS DEL DOCENTE ─── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_datos_docente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <!-- Encabezado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_person"
                            android:contentDescription="@null"
                            app:tint="@color/tec_red" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/docentes_section_datos"
                            android:textColor="@color/tec_red"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                    </LinearLayout>

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp"
                        android:background="@color/tec_red_light" />

                    <!-- No. de Empleado -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/docentes_label_no_empleado"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_no_empleado"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="14dp"
                        android:hint="@string/docentes_hint_no_empleado"
                        app:boxStrokeColor="@color/tec_red"
                        app:hintTextColor="@color/tec_red"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:startIconDrawable="@drawable/ic_badge"
                        app:startIconTint="@color/tec_red">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_no_empleado"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLength="12"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Nombre -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/docentes_label_nombre"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_nombre_docente"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="14dp"
                        android:hint="@string/docentes_hint_nombre"
                        app:boxStrokeColor="@color/tec_red"
                        app:hintTextColor="@color/tec_red"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/tec_red">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_nombre_docente"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Dirección -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/docentes_label_direccion"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_direccion"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:hint="@string/docentes_hint_direccion"
                        app:boxStrokeColor="@color/tec_red"
                        app:hintTextColor="@color/tec_red"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/tec_red">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_direccion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress|textCapSentences"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <!-- ─── CARD: MATERIAS POR ALUMNO Y CALIFICACIONES ─── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_materias_alumnos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <!-- Encabezado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_school"
                            android:contentDescription="@null"
                            app:tint="@color/tec_red" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/docentes_section_materias"
                            android:textColor="@color/tec_red"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                    </LinearLayout>

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/tec_red_light" />

                    <!-- Selector de Alumno -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/docentes_label_alumno"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_selector_alumno"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="14dp"
                        android:hint="@string/docentes_hint_alumno"
                        app:boxStrokeColor="@color/tec_red"
                        app:hintTextColor="@color/tec_red"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp">

                        <AutoCompleteTextView
                            android:id="@+id/acv_selector_alumno"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Tabla: cabecera -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:background="@color/tec_red_light"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="10dp"
                            android:text="@string/docentes_col_materia"
                            android:textColor="@color/tec_red"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:paddingEnd="10dp"
                            android:text="@string/docentes_col_calificacion"
                            android:textAlignment="textEnd"
                            android:textColor="@color/tec_red"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:paddingEnd="10dp"
                            android:text="@string/docentes_col_accion"
                            android:textAlignment="textEnd"
                            android:textColor="@color/tec_red"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                    </LinearLayout>

                    <!-- Fila 1: Materia + Calificación + Botón Asignar -->
                    <include layout="@layout/item_docente_materia"
                        android:id="@+id/item_doc_materia_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Fila 2 -->
                    <include layout="@layout/item_docente_materia"
                        android:id="@+id/item_doc_materia_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Fila 3 -->
                    <include layout="@layout/item_docente_materia"
                        android:id="@+id/item_doc_materia_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Fila 4 -->
                    <include layout="@layout/item_docente_materia"
                        android:id="@+id/item_doc_materia_4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Fila 5 -->
                    <include layout="@layout/item_docente_materia"
                        android:id="@+id/item_doc_materia_5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Espacio inferior -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
