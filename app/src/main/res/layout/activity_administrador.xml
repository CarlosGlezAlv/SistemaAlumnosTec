<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/admin_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_bg">

    <!-- AppBar con toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_admin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_admin"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/tec_red"
            app:title="@string/admin_title"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido con scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ─── BIENVENIDA ADMIN ─── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_admin_bienvenida"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/tec_red">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_admin"
                        android:contentDescription="@null"
                        app:tint="@color/white" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_bienvenida"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_bienvenida_sub"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <!-- ─── CARD: GESTIÓN DE ALUMNOS ─── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_admin_alumnos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <!-- Encabezado sección -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_person"
                            android:contentDescription="@null"
                            app:tint="@color/tec_red" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/admin_section_alumnos"
                            android:textColor="@color/tec_red"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp"
                        android:background="@color/tec_red_light" />

                    <!-- Botones CRUD -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:useDefaultMargins="true">

                        <!-- Alta -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_alta_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_alta"
                            android:textColor="@color/tec_red"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_add"
                            app:iconTint="@color/tec_red"
                            app:strokeColor="@color/tec_red"
                            app:cornerRadius="10dp" />

                        <!-- Visualizar -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ver_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_ver"
                            android:textColor="@color/tec_red"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_visibility"
                            app:iconTint="@color/tec_red"
                            app:strokeColor="@color/tec_red"
                            app:cornerRadius="10dp" />

                        <!-- Editar -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_editar_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_editar"
                            android:textColor="@color/tec_red"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_edit"
                            app:iconTint="@color/tec_red"
                            app:strokeColor="@color/tec_red"
                            app:cornerRadius="10dp" />

                        <!-- Eliminar -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_eliminar_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_eliminar"
                            android:textColor="@color/admin_danger"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_delete"
                            app:iconTint="@color/admin_danger"
                            app:strokeColor="@color/admin_danger"
                            app:cornerRadius="10dp" />

                    </GridLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <!-- ─── CARD: GESTIÓN DE DOCENTES ─── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_admin_docentes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_school"
                            android:contentDescription="@null"
                            app:tint="@color/tec_red" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/admin_section_docentes"
                            android:textColor="@color/tec_red"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp"
                        android:background="@color/tec_red_light" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:useDefaultMargins="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_alta_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_alta"
                            android:textColor="@color/tec_red"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_add"
                            app:iconTint="@color/tec_red"
                            app:strokeColor="@color/tec_red"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ver_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_ver"
                            android:textColor="@color/tec_red"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_visibility"
                            app:iconTint="@color/tec_red"
                            app:strokeColor="@color/tec_red"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_editar_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_editar"
                            android:textColor="@color/tec_red"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_edit"
                            app:iconTint="@color/tec_red"
                            app:strokeColor="@color/tec_red"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_eliminar_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_eliminar"
                            android:textColor="@color/admin_danger"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_delete"
                            app:iconTint="@color/admin_danger"
                            app:strokeColor="@color/admin_danger"
                            app:cornerRadius="10dp" />

                    </GridLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <!-- ─── CARD: GESTIÓN DE MATERIAS ─── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_admin_materias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_book"
                            android:contentDescription="@null"
                            app:tint="@color/tec_red" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/admin_section_materias"
                            android:textColor="@color/tec_red"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp"
                        android:background="@color/tec_red_light" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:useDefaultMargins="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_alta_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_alta"
                            android:textColor="@color/tec_red"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_add"
                            app:iconTint="@color/tec_red"
                            app:strokeColor="@color/tec_red"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ver_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_ver"
                            android:textColor="@color/tec_red"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_visibility"
                            app:iconTint="@color/tec_red"
                            app:strokeColor="@color/tec_red"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_editar_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_editar"
                            android:textColor="@color/tec_red"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_edit"
                            app:iconTint="@color/tec_red"
                            app:strokeColor="@color/tec_red"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_eliminar_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:text="@string/admin_btn_eliminar"
                            android:textColor="@color/admin_danger"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_delete"
                            app:iconTint="@color/admin_danger"
                            app:strokeColor="@color/admin_danger"
                            app:cornerRadius="10dp" />

                    </GridLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Espacio inferior -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
